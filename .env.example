# Copy this to .env and fill in real values.
# On Railway, set these as environment variables in the dashboard.

# ── Discord Bot ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here

# ── Verification website ─────────────────────────────────────────────────────
# The public domain where the API server is reachable.
# On Replit this is set automatically. On Railway, set it to your service domain.
# Example: my-api.up.railway.app
APP_DOMAIN=

# ── Shared data file ─────────────────────────────────────────────────────────
# Absolute path to the verifications JSON file.
# Both the bot and the API server must point to the same file.
# On Railway, mount a shared volume and set this to a path on that volume.
# Example: /data/verifications.json
VERIFICATIONS_FILE=
